{
  "manifest_version": 2,
  "name": "Van Dijk Ad Blocker",
  "version": "1.0.0",
  "description": "A lightweight ad blocker extension",
  "icons": {
    "48": "icons/icon.svg",
    "96": "icons/icon.svg"
  },
  "permissions": [
    "webRequest",
    "webRequestBlocking",
    "<all_urls>",
    "storage",
    "tabs"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "browser_action": {
    "default_icon": {
      "48": "icons/icon.svg"
    },
    "default_title": "Van Dijk Ad Blocker",
    "default_popup": "popup.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "{7c8e9f3a-2b4d-4a1e-9c5f-8d7e6a3b2c1f}",
      "strict_min_version": "57.0"
    }
  }
}
